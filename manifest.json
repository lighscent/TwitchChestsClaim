{
    "manifest_version": 3,
    "name": "TwitchChestsClaim",
    "version": "1.1.0",
    "author": "augustin.pro.prs@gmail.com",
    "description": "Claim Twitch chests automatically",
    "permissions": [
        "storage"
    ],
    "content_scripts": [
        {
            "matches": [
                "https://www.twitch.tv/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html"
    }
}